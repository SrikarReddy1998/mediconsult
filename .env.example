# MediConsult AI (TypeScript) — environment configuration
# Copy to .env and fill in.

# Where the patient record + database live.
# Leave this UNSET (commented out) to use ~/patient_data automatically on any OS.
# To override, use an ABSOLUTE path:
#   macOS/Linux:  /home/you/patient_data
#   Windows:      C:/Users/you/patient_data   (forward slashes are fine)
# MEDICONSULT_DATA=

# ── LLM PROVIDER — the server's OWN reasoning (report extraction + specialist review) ──
# Pick your model by setting its key. When ANY cloud key below is set, the local
# Ollama fallback is DISABLED automatically (Claude/GPT are used instead of the slow
# local 7Bs). Set MEDICONSULT_ALLOW_OLLAMA=1 to keep Ollama as an offline last resort.
# NOTE: a Claude Pro / ChatGPT subscription powers the CHAT client (front-end); the
# server's own calls still need an API key or token, as below.

# Claude (recommended) — Anthropic API key (paid per-token; NOT the same as a Claude
# Pro subscription): console.anthropic.com. Primary provider when set.
ANTHROPIC_API_KEY=
# MEDICONSULT_ANTHROPIC_MODEL=claude-opus-4-8   # or claude-sonnet-5 (cheaper), claude-haiku-4-5

# GPT via GitHub Models (uses your GitHub account, no card): github.com/marketplace/models
GITHUB_TOKEN=
# Other free tiers (optional): aistudio.google.com / console.groq.com
GOOGLE_API_KEY=
GROQ_API_KEY=

# Local Ollama — offline fallback, used only when NO cloud key is set (or when
# MEDICONSULT_ALLOW_OLLAMA=1). Reached via ${OLLAMA_HOST}/v1.
# MEDICONSULT_ALLOW_OLLAMA=1
OLLAMA_HOST=http://localhost:11434
MEDICONSULT_LOCAL_MEDICAL=meditron:7b
MEDICONSULT_LOCAL_GENERAL=qwen2.5:7b
MEDICONSULT_LOCAL_REASON=qwen2.5:7b

# Signing secret for remote bearer tokens (remote server is a follow-up).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MEDICONSULT_AUTH_SECRET=

# ntfy topic for push alerts (optional; alerts are always stored in the DB)
MEDICONSULT_NTFY_TOPIC=
