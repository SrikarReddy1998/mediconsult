# MediConsult AI (TypeScript) — environment configuration
# Copy to .env and fill in. All keys below are FREE-TIER (no credit card).

# Where the patient record + database live
MEDICONSULT_DATA=/home/youruser/patient_data

# Local Ollama (the fallback that never runs out) — default is fine.
# Reached via its OpenAI-compatible endpoint at ${OLLAMA_HOST}/v1
OLLAMA_HOST=http://localhost:11434

# Local model names (must be pulled: `ollama pull <name>`)
MEDICONSULT_LOCAL_MEDICAL=meditron:7b
MEDICONSULT_LOCAL_GENERAL=qwen2.5:7b
MEDICONSULT_LOCAL_REASON=qwen2.5:7b

# ── FREE LLM API KEYS (the fallback chain, in priority order) ──
# aistudio.google.com (no card)
GOOGLE_API_KEY=
# console.groq.com (no card)
GROQ_API_KEY=
# github.com/marketplace/models (uses your GitHub account)
GITHUB_TOKEN=

# Signing secret for remote bearer tokens (remote server is a follow-up).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MEDICONSULT_AUTH_SECRET=

# ntfy topic for push alerts (optional; alerts are always stored in the DB)
MEDICONSULT_NTFY_TOPIC=
